# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Environment variables
.env
.env.*

# Go workspace
go.work

# OS-specific files
.DS_Store
Thumbs.db

# -----------------
# TERRAFORM SECRETS
# -----------------
# Local .terraform directories
**/.terraform/*

# .tfstate files (Ini BAHAYA jika bocor ke GitHub)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and not
# intended to be committed.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc
